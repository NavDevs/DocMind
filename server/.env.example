# ==============================================
# DocMind Backend — Environment Variables
# Copy this file to .env and fill in your values
# ==============================================

# Server
PORT=5000
NODE_ENV=development
CLIENT_URL=http://localhost:5173

# MongoDB Atlas
# Get your URI from: https://cloud.mongodb.com
# Format: mongodb+srv://<username>:<password>@cluster0.mongodb.net/docmind?retryWrites=true&w=majority
MONGO_URI=mongodb+srv://<username>:<password>@cluster0.mongodb.net/docmind?retryWrites=true&w=majority

# JWT Authentication
# Generate a secure secret: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
JWT_SECRET=change_this_to_a_random_32_char_string
JWT_EXPIRES_IN=7d

# OpenAI
# Required for: PDF summaries, embeddings, and RAG chat answers
# The app runs in degraded mode without this (upload/list still works)
# Get your key from: https://platform.openai.com/api-keys
OPENAI_API_KEY=sk-your-openai-api-key-here

# Vector Store
# "local"    = In-memory store (data lost on server restart, suitable for dev)
# "pinecone" = Persistent vector DB (recommended for production)
VECTOR_STORE=local

# Optional: Pinecone (only needed if VECTOR_STORE=pinecone)
# Get your API key from: https://app.pinecone.io
PINECONE_API_KEY=
PINECONE_INDEX_NAME=docmind-index
PINECONE_ENVIRONMENT=us-east-1
